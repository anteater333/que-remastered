model User {
  id                String   @id @default(uuid()) // userId
  handle            String   @unique // 사람이 읽을 수 있는 사용자 고유 ID
  email             String   @unique
  password          String
  nickname          String?
  profilePictureUrl String?
  description       String?
  registeredAt      DateTime @default(now())

  // 사용자 권한
  role Role @default(USER)

  studio Studio?

  // 리액션 정보
  givenLikes  StageLikes[]
  givenScores StageScore[]

  // db mapping
  @@map("users") // 실제 DB 테이블 이름을 소문자로 설정
}

enum Role {
  USER
  OWNER
}
