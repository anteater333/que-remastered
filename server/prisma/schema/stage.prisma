model Stage {
  id          String @id @default(cuid())
  title       String
  description String @db.Text

  // 영상 파일 관련
  sourceUrl          String?
  thumbnailUrl       String?
  thumbnailUrlMedium String?
  length             Int              @default(0)
  orientation        StageOrientation @default(UNSET)

  // 업로드 상태
  status StageStatus @default(INITIATED)

  viewCount  Int      @default(0)
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  studioId   String
  studio     Studio   @relation(fields: [studioId], references: [id])

  isPublished Boolean @default(false)

  // 언젠가 기획이 된다면
  // songId String?
  // song   Song?   @relation(fields: [songId], references: [id])

  likes  StageLikes[]
  scores StageScore[]
  views  StageView[]

  // 인덱스 설정 구역
  @@index([isPublished, uploadedAt(sort: Desc)]) // 일반 유저 리스트 조회 + 최신순 정렬 최적화
  @@index([status]) // 백엔드 워커(인코딩 큐) 상태 조회 최적화
  @@index([studioId]) // "내가 업로드한 영상 목록" 조회 최적화
  // db mapping
  @@map("stages")
}

enum StageStatus {
  INITIATED // 레코드 막 생성됨, 영상 업로드 시작 안됨
  UPLOADING // 원본 영상 업로드 스트리밍 시작
  QUEUED // 업로드 완료 후 큐에 등록 된 상태
  PROCESSING // 워커에서 처리 중
  DONE // 처리 완료
  FAILED // 실패  
}

enum StageOrientation {
  UNSET
  PORTRAIT
  LANDSCAPE
  SQUARE
}

model StageLikes {
  id        String   @id @default(cuid())
  stageId   String
  userId    String
  stage     Stage    @relation(fields: [stageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([stageId, userId]) // 중복 방지
  @@index([userId])
  @@map("stageLikes")
}

model StageScore {
  id          String   @id @default(cuid())
  stageId     String
  userId      String
  stage       Stage    @relation(fields: [stageId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  vocalScore  Int
  visualScore Int
  vibeScore   Int
  createdAt   DateTime @default(now())

  @@unique([stageId, userId]) // 중복 방지
  @@index([userId])
  @@map("stageScores")
}

model StageView {
  id        String   @id @default(cuid())
  stageId   String
  userId    String? // 비로그인 시청 허용, nullable
  stage     Stage    @relation(fields: [stageId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([stageId])
  @@map("stageViews")
}
